# Copy to .env for local development (never commit .env).
# Or run: cp .env.example .env and fill values from Supabase Dashboard → Settings → API.

# --- Client (embedded in the browser bundle; safe to expose) ---
# Required for Supabase auth and data from the browser.
VITE_SUPABASE_URL=https://zoldrdsidhnreioxqhhk.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-supabase-dashboard

# GitHub Pages project site base path. Omit locally (defaults to /).
# CI sets this automatically from GITHUB_REPOSITORY; override if needed:
# VITE_BASE_PATH=/auto_mail_sender/

# --- Server (local dev / full-stack deploy only; NOT used on static GitHub Pages) ---
# Used by createServerFn handlers (email send, campaigns) when running `vite dev` or Nitro deploy.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Build toggles (optional) ---
# NITRO_PRESET=cloudflare-module
# VITE_SPA=false
# VITE_PRERENDER=false
